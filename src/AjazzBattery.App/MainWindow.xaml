<Window x:Class="AjazzBattery.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="AJAZZ AJ179 APEX - Монитор батареи" Height="480" Width="640"
        WindowStartupLocation="CenterScreen" Background="#1E1E2E" Foreground="#CDD6F4">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,20">
            <TextBlock Text="AJAZZ AJ179 APEX" FontSize="22" FontWeight="Bold" Foreground="#F5E0DC"/>
            <TextBlock x:Name="StatusBadgeText" Text="[Подключена]" FontSize="14" Margin="15,4,0,0" Foreground="#A6E3A1"/>
        </StackPanel>

        <!-- Content Area -->
        <TabControl Grid.Row="1" Background="#181825" BorderBrush="#313244" Foreground="#CDD6F4">
            <!-- Overview Tab -->
            <TabItem Header="Обзор" Foreground="#CDD6F4">
                <Grid Margin="15">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,10">
                        <TextBlock Text="Текущий заряд: " FontSize="18" Foreground="#BAC2DE"/>
                        <TextBlock x:Name="PercentText" Text="74%" FontSize="24" FontWeight="Bold" Foreground="#A6E3A1"/>
                    </StackPanel>

                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,5">
                        <TextBlock Text="Состояние: " FontSize="14" Foreground="#BAC2DE"/>
                        <TextBlock x:Name="StateText" Text="Активна (2.4 GHz)" FontSize="14" FontWeight="SemiBold" Foreground="#CDD6F4"/>
                    </StackPanel>

                    <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,5">
                        <TextBlock Text="Последнее обновление: " FontSize="14" Foreground="#BAC2DE"/>
                        <TextBlock x:Name="LastUpdatedText" Text="21:43:12" FontSize="14" Foreground="#CDD6F4"/>
                    </StackPanel>

                    <StackPanel Grid.Row="3" Margin="0,20,0,0">
                        <TextBlock Text="Диагностическое сообщение:" FontSize="12" Foreground="#A6ADC8"/>
                        <TextBlock x:Name="DiagMessageText" Text="Опрос устройства выполняется без ошибок." FontSize="12" Foreground="#89B4FA" TextWrapping="Wrap"/>
                    </StackPanel>
                </Grid>
            </TabItem>

            <!-- History Tab -->
            <TabItem Header="История" Foreground="#CDD6F4">
                <DataGrid x:Name="HistoryGrid" AutoGenerateColumns="True" Background="#181825" Foreground="#CDD6F4" RowBackground="#1E1E2E" Margin="10"/>
            </TabItem>

            <!-- Settings Tab -->
            <TabItem Header="Настройки" Foreground="#CDD6F4">
                <StackPanel Margin="15">
                    <CheckBox x:Name="AutoStartCheckBox" Content="Запускать вместе с Windows (HKCU Run)" Foreground="#CDD6F4" FontSize="14" Margin="0,10" Checked="AutoStartCheckBox_Changed" Unchecked="AutoStartCheckBox_Changed"/>
                    <CheckBox x:Name="NotificationsCheckBox" Content="Показывать всплывающие уведомления о батарее" Foreground="#CDD6F4" FontSize="14" Margin="0,10" IsChecked="True"/>
                    <CheckBox x:Name="ExperimentalProfilesCheckBox" Content="Включить экспериментальные профили мышей" Foreground="#CDD6F4" FontSize="14" Margin="0,10"/>
                </StackPanel>
            </TabItem>
        </TabControl>

        <!-- Footer Buttons -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
            <Button x:Name="RefreshButton" Content="Обновить сейчас" Width="140" Height="32" Click="RefreshButton_Click" Background="#45475A" Foreground="#CDD6F4" Margin="0,0,10,0"/>
            <Button x:Name="CloseButton" Content="Скрыть в трей" Width="120" Height="32" Click="CloseButton_Click" Background="#313244" Foreground="#CDD6F4"/>
        </StackPanel>
    </Grid>
</Window>
